#Backend API base URL
VITE_API_BASE=http://localhost:5000/api

#FIREBASE CONFIGURATION (get from Firebase Console > Project Settings > Your Apps)

#API key
VITE_FIREBASE_API_KEY=your_api_key

#Project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

#Auth Domain (format: your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

#Storage Bucket (format: your-project-id.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

#Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER=your_messaging_sender_id

#Firebase app ID
VITE_FIREBASE_APP_ID=your_app_id

# File Upload Configuration
VITE_MAX_SIZE_MB=5
